    p(surf,GROUND_BR,0,GROUND_Y+9,W,H-GROUND_Y)
    step=36
    off=offset%step                          # ← keep offset always within one tile
    row_h=18
    for ry in range(GROUND_Y+9,H,row_h):
        ri=(ry-(GROUND_Y+9))//row_h
        sh=(step//2) if ri%2==0 else 0
        p(surf,GROUND_DK,0,ry,W,2)
        for cx in range(-off+sh,W+step,step):
            p(surf,GROUND_DK,cx,ry,2,row_h)
        for cx in range(-off+sh+2,W+step,step):
            p(surf,GROUND_LT,cx,ry+2,step-4,4)

def draw_hills(surf, offset, night):
    c1=HILL_C if not night else (0,50,0)
    c2=HILL_D if not night else (0,36,0)
    ct=HILL_T if not night else (0,64,0)
    hx_start = int(-(offset*0.25) % 340) - 340   # ← wrap in int()
    for hx in range(hx_start, W+340, 340):
        pygame.draw.ellipse(surf,c1,(hx,GROUND_Y-58,180,72))
        pygame.draw.ellipse(surf,ct,(hx+10,GROUND_Y-56,160,28))
        pygame.draw.ellipse(surf,c2,(hx+165,GROUND_Y-40,130,52))

def draw_cloud(surf, x, y):
    for cx,cy,cr in [(x+16,y+20,18),(x+32,y+10,24),(x+56,y+7,27),(x+80,y+10,22),(x+96,y+20,16)]:
        pygame.draw.circle(surf,CLOUD_W,(int(cx),int(cy)),cr)
        pygame.draw.circle(surf,CLOUD_SH,(int(cx),int(cy)+cr-4),cr//3)
    p(surf,CLOUD_W,x+2,y+20,112,18); p(surf,CLOUD_SH,x+2,y+30,112,8)

def draw_stars_moon(surf, stars, moon_x):
    for sx,sy,ss in stars: pygame.draw.circle(surf,STAR_C,(sx,sy),ss)
    mx=int(moon_x)
    pygame.draw.circle(surf,MOON_C,(mx,52),28)
    pygame.draw.circle(surf,SKY_NIGHT,(mx+14,47),24)

def draw_coin_hud(surf, x, y):
    pygame.draw.circle(surf,COIN_Y,(x,y),9)
    pygame.draw.circle(surf,COIN_D,(x+3,y),6)

def shadow_text(surf, font, text, color, x, y):
    surf.blit(font.render(text,True,SCORE_SH),(x+2,y+2))
    surf.blit(font.render(text,True,color),(x,y))

