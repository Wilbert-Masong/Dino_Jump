def make_beep(freq=440, duration=0.1, volume=0.3):
    sample_rate = 44100
    frames = int(sample_rate * duration)
    t = np.linspace(0, duration, frames, False)
    wave = (np.sin(2 * np.pi * freq * t) * volume * 32767).astype(np.int16)
    wave = np.column_stack([wave, wave])
    return pygame.sndarray.make_sound(wave)

def make_note(freq, duration, volume=0.3):   # ← ADD this function
    sample_rate = 44100
    frames = int(sample_rate * duration)
    t = np.linspace(0, duration, frames, False)
    wave_data = (np.sin(2 * np.pi * freq * t) * volume * 32767).astype(np.int16)
    return np.column_stack([wave_data, wave_data])

def make_theme():
    # Mario theme notes (freq, duration)
    E5, C5, G4, A4, B4 = 659, 523, 392, 440, 494
    F5, D5, Gs4        = 698, 587, 415
    notes = [
        (E5,0.15),(E5,0.15),(0,0.15),(E5,0.15),(0,0.15),(C5,0.15),(E5,0.30),
        (G4,0.30),(0,0.30),(C5,0.30),(0,0.15),(G4,0.30),(0,0.30),
        (E5,0.30),(0,0.15),(A4,0.30),(B4,0.15),(0,0.10),(Gs4,0.15),
        (A4,0.30),(F5,0.20),(G4,0.15),(0,0.10),(E5,0.30),
        (C5,0.20),(D5,0.15),(B4,0.25),(0,0.20),
    ]
    chunks = []
    for freq, dur in notes:
        if freq == 0:
            silence = np.zeros((int(44100*dur), 2), dtype=np.int16)
            chunks.append(silence)
        else:
            chunks.append(make_note(freq, dur))
    return np.concatenate(chunks)

def save_wav(data, filename):
    with wave.open(filename, 'w') as wf:
        wf.setnchannels(2)
        wf.setsampwidth(2)
        wf.setframerate(44100)
        wf.writeframes(data.tobytes())

