# ─────────────────────────────────────────────────────────────
# GAME STATE
# ─────────────────────────────────────────────────────────────
def new_game(hi):
    return {
        "mx":80,"my":float(GROUND_Y-66),
        "mvy":0.0,"on_ground":True,"ducking":False,"airborne":False,
        "jumps_left":2,        # double jump counter (2 = can jump twice)
        "on_brick":False,"brick_platform_y":None,
        "obstacles":[],
        "clouds":[{"x":float(random.randint(0,W)),"y":float(random.randint(30,130))} for _ in range(5)],
        "ground_off":0,
        "hill_off":0.0,
        "score":0.0,"coins":0,"hi":hi,
        "speed":6.0,"frame":0,
        "over":False,"flash":0,
        "night":False,"transition":0,
        "next_night":random.randint(200,500),
        "stars":[(random.randint(0,W),random.randint(10,GROUND_Y-30),random.randint(1,3)) for _ in range(55)],
        "moon_x":float(W-100),
        "spawn_t":300,         # longer first gap so player can settle in
    }

hi_score = 0
state    = new_game(0)
game_phase = "start"   # "start" | "play"
start_frame = 0

# ─────────────────────────────────────────────────────────────
# OBSTACLE SPAWNER  — difficulty scales with score, fewer at extremes
# ─────────────────────────────────────────────────────────────
def spawn_obstacle(state):
    sc = int(state["score"])
    pool = []

    # ── early game (0-80): only simple short pipes ──────────
    if sc < 40:
        pool = [("pipe",0,0),("pipe",0,0),("pipe",1,0)]   # only short narrow pipes

    # ── building up (40-150): wider + taller pipes + goombas ─
    elif sc < 150:
        for wc in range(2):
            pool.append(("pipe",wc,0))
        if sc > 60:
            pool += [("goomba",0,0)]*3
        if sc > 90:
            pool.append(("pipe",0,1))

    # ── mid game (150-400): full variety ────────────────────
    elif sc < 400:
        for wc in range(3):
            for hc in range(2):
                pool.append(("pipe",wc,hc))
        pool += [("goomba",0,0)]*3
        if sc > 110: pool += [("shell",0,0)]*2
        if sc > 150: pool += [("bullet",0,0)]*2
        for wc in range(3):
            if sc > 40: pool += [("piranha",wc,0)]*2
        if sc > 100:
            for cnt in range(3,6):
                pool.append(("fbrick",cnt,0))
                pool.append(("fbrick",cnt,1))

    # ── late game (400+): speed is the main challenge, fewer obstacles ─
    else:
        # Shrink pool back — mostly simpler obstacles + speed
        pool = [("pipe",0,0)]*3+[("pipe",1,0)]*2+[("goomba",0,0)]*2
        pool += [("bullet",0,0)]*2+[("shell",0,0)]
        pool += [("fbrick",2,0),("fbrick",3,0),("fbrick",2,1)]
        if sc > 600:
            pool += [("piranha",0,0)]*2   # re-add piranhas at very high score

    kind,a,b = random.choice(pool)

    if kind=="pipe":
        return {"kind":"pipe","x":float(W+20),"wc":a,"hc":b}
    elif kind=="piranha":
        return {"kind":"piranha","x":float(W+20),"wc":a,"hc":b}
    elif kind=="goomba":
        return {"kind":"goomba","x":float(W+20),"y":float(GROUND_Y-56)}
    elif kind=="shell":
        return {"kind":"shell","x":float(W+20),"y":float(GROUND_Y-KSC*12-4)}
    elif kind=="bullet":
        fly_y=float(GROUND_Y-bullet_bill_height()-random.randint(10,120))
        return {"kind":"bullet","x":float(W+40),"y":fly_y}
    else:
        brick_y=(GROUND_Y-100) if b==0 else (GROUND_Y-148)
        count=a
        collected=[True] * count
    if random.random() < 0.5:
        lucky = random.randint(0, count-1)
        collected[lucky] = False
    return {"kind":"fbrick","x":float(W+20),"y":float(brick_y),"count":count,"collected":collected}

# ─────────────────────────────────────────────────────────────
# SPAWN INTERVAL — longer gaps at very early and very late game
# ─────────────────────────────────────────────────────────────
def next_spawn_time(sc):
    if sc < 30:
        return float(random.randint(800, 1200))   # very sparse early
    elif sc < 100:
        return float(random.randint(650, 950))
    elif sc < 400:
        return float(random.randint(550, 800))    # mid-game still has breathing room
    else:
        return float(random.randint(700, 1000))   # late game: wide gaps, speed is the challenge

# ─────────────────────────────────────────────────────────────
# MAIN LOOP
# ─────────────────────────────────────────────────────────────
while True:
    clock.tick(FPS)

    for event in pygame.event.get():
        if event.type == pygame.QUIT:
            pygame.quit(); sys.exit()
        if event.type == pygame.KEYDOWN:
            if event.key == pygame.K_ESCAPE:
                pygame.quit(); sys.exit()

            # ── Start screen ──────────────────────────────────
            if game_phase == "start":
                if event.key in (pygame.K_SPACE, pygame.K_RETURN, pygame.K_UP):
                    game_phase = "play"
                    state = new_game(hi_score)
                    pygame.mixer.music.rewind()
                    pygame.mixer.music.play(-1)
                    popups.clear()

            # ── Game over restart ─────────────────────────────
            elif state["over"]:
                if event.key in (pygame.K_SPACE, pygame.K_RETURN, pygame.K_UP):
                    hi_score=max(hi_score,int(state["score"]))
                    saved_coins = state["coins"]  
                    popups.clear(); state=new_game(hi_score)
                    state["coins"] = saved_coins  
                    pygame.mixer.music.rewind()     
                    pygame.mixer.music.play(-1) 

            # ── In-game controls ──────────────────────────────
            else:
                if event.key in (pygame.K_SPACE, pygame.K_UP, pygame.K_w):
                    can_jump = state["on_ground"] or state["on_brick"] or state["jumps_left"] > 0
                    if can_jump:
                        state["mvy"]      = JUMP_V
                        state["airborne"] = True
                        state["ducking"]  = False
                        if state["on_ground"] or state["on_brick"]:
                            state["jumps_left"] = 1   # used first jump; 1 double-jump remaining
                            sfx_jump.play()
                        else:
                            state["jumps_left"] -= 1  # used double jump
                            sfx_jump2.play()
                        state["on_ground"] = False
                        state["on_brick"]  = False

                if event.key == pygame.K_DOWN:
                    if not state["on_ground"] and not state["on_brick"]:
                        state["mvy"] = max(state["mvy"], 5)
                    elif state["on_brick"]:
                        state["on_brick"]=False; state["mvy"]=2.0

    keys = pygame.key.get_pressed()

    # ── START SCREEN DRAW ─────────────────────────────────────
    if game_phase == "start":
        start_frame += 1
        draw_start_screen(screen, start_frame, hi_score)
        pygame.display.flip()
        continue

    # ── DUCK (hold) ───────────────────────────────────────────
    if not state["over"]:
        state["ducking"] = (keys[pygame.K_DOWN] or keys[pygame.K_s]) and state["on_ground"]

    # ── UPDATE ────────────────────────────────────────────────
    if not state["over"]:
        if not state["on_brick"]:
            state["mvy"] += GRAVITY
        state["my"] += state["mvy"]

        floor_y = GROUND_Y-(DUCK_H+28 if state["ducking"] else 66)
        if state["my"] >= floor_y:
            state["my"]=float(floor_y); state["mvy"]=0.0
            state["on_ground"]=True; state["on_brick"]=False
            state["airborne"]=False; state["jumps_left"]=2   # reset jumps on ground

        prev_sc = int(state["score"])
        state["score"] += state["speed"]*0.02
        state["speed"]  = min(6.0+int(state["score"])//150*0.5, 20.0)
        state["frame"] += 1
        sc = int(state["score"])

        if sc // 100 > prev_sc // 100:         
            sfx_milestone.play()
            add_popup(W//2 - 60, H//2 - 60, f"{sc} POINTS!", (252, 218, 80))

        if sc >= state["next_night"] and state["transition"]==0:
            state["transition"]=60
        if state["transition"]>0:
            state["transition"]-=1
            if state["transition"]==0:
                state["night"]=not state["night"]
                state["next_night"]=sc+random.randint(280,650)

        state["ground_off"]=(state["ground_off"]+int(state["speed"]))%36
        state["hill_off"]=(state["hill_off"]+state["speed"]*0.25)%(340*4)
        state["moon_x"]-=state["speed"]*0.25
        if state["moon_x"]<-50: state["moon_x"]=float(W+50)
        for c in state["clouds"]:
            c["x"]-=state["speed"]*0.35
            if c["x"]<-150:
                c["x"]=float(W+random.randint(0,80)); c["y"]=float(random.randint(30,130))

        state["spawn_t"]-=state["speed"]
        if state["spawn_t"]<=0:
            state["spawn_t"]=next_spawn_time(sc)
            state["obstacles"].append(spawn_obstacle(state))

        state["obstacles"]=[o for o in state["obstacles"] if o["x"]>-300]
        for o in state["obstacles"]:
            o["x"]-=state["speed"]

        # ── Brick stepping + coin collection ─────────────────
        mario_r    = mario_rect(state["mx"],int(state["my"]),state["ducking"])
        mario_feet = mario_r.bottom
        mario_cx   = mario_r.centerx

        was_on_brick = state["on_brick"]
        state["on_brick"]=False; state["brick_platform_y"]=None

        for o in state["obstacles"]:
            if o["kind"]=="fbrick":
                ox=int(o["x"])
                br=flying_bricks_rect(ox,int(o["y"]),o["count"])
                brick_top=int(o["y"])

                if (mario_cx>=br.left and mario_cx<=br.right and
                    state["mvy"]>=0 and
                    mario_feet>=brick_top and mario_feet<=brick_top+18+abs(state["mvy"])+4):
                    mario_height=DUCK_H if state["ducking"] else 66
                    state["my"]=float(brick_top-mario_height-S)
                    state["mvy"]=0.0; state["on_brick"]=True; sfx_land.play()
                    state["brick_platform_y"]=brick_top
                    state["airborne"]=False; state["jumps_left"]=2  # reset jumps on brick

                for i in range(o["count"]):
                    if not o["collected"][i]:
                        cr=coin_rect_at(ox,int(o["y"]),i)
                        if mario_r.inflate(4,4).colliderect(cr):
                            o["collected"][i]=True; state["coins"]+=1
                            sfx_coin.play()
                            add_popup(ox+i*BW+BW//2,int(o["y"])-24,"+COIN",COIN_Y)

        if state["on_brick"]:
            still_on=any(
                o["kind"]=="fbrick" and
                mario_cx>=flying_bricks_rect(int(o["x"]),int(o["y"]),o["count"]).left and
                mario_cx<=flying_bricks_rect(int(o["x"]),int(o["y"]),o["count"]).right
                for o in state["obstacles"]
            )
            if not still_on: state["on_brick"]=False

        # ── Collision (harm) ──────────────────────────────────
        mr=mario_rect(state["mx"],int(state["my"]),state["ducking"])
        hit=False
        for o in state["obstacles"]:
            ox=int(o["x"])
            if o["kind"] in ("pipe","piranha"):
                hr=pipe_rect(ox,o["wc"],o["hc"]).inflate(-6,-4)
                if mr.colliderect(hr): hit=True; break
                if o["kind"]=="piranha":
                    ptop=pipe_cap_top(ox,o["wc"],o["hc"])
                    phr=piranha_rect(ox,ptop,state["frame"],o["wc"],o["hc"]).inflate(-4,-4)
                    if mr.colliderect(phr): hit=True; break
            elif o["kind"]=="goomba":
                if mr.colliderect(goomba_rect(o["x"],o["y"]).inflate(-6,-4)): hit=True; break
            elif o["kind"]=="shell":
                if mr.colliderect(koopa_rect(o["x"],o["y"]).inflate(-6,-4)): hit=True; break
            elif o["kind"]=="bullet":
                if mr.colliderect(bullet_bill_rect(o["x"],o["y"]).inflate(-4,-4)): hit=True; break
            elif o["kind"]=="fbrick":
                ox2=int(o["x"]); br=flying_bricks_rect(ox2,int(o["y"]),o["count"])
                side_rect=pygame.Rect(br.left-4,br.top+4,8,br.height-8)
                if mr.colliderect(side_rect) and not state["on_brick"]: hit=True; break

        if hit:
            hi_score=max(hi_score,sc); state["hi"]=hi_score
            pygame.mixer.music.pause()
           # ✅ Correct
            state["over"]=True; state["flash"]=14
            pygame.mixer.music.stop() 
            for snd in sfx_death:
                snd.play()

    for pp in popups:
        pp["y"]-=1.2; pp["life"]-=1
    popups[:]=[pp for pp in popups if pp["life"]>0]

    # ── DRAW ─────────────────────────────────────────────────
    sky=SKY_NIGHT if state["night"] else SKY_DAY
    if state["transition"]>0:
        t=1-state["transition"]/60
        src=SKY_DAY if not state["night"] else SKY_NIGHT
        dst=SKY_NIGHT if not state["night"] else SKY_DAY
        sky=tuple(int(src[i]+(dst[i]-src[i])*t) for i in range(3))
    screen.fill(sky)

    if state["night"] or state["transition"]>0:
        draw_stars_moon(screen,state["stars"],state["moon_x"])
    draw_hills(screen,state["hill_off"],state["night"])
    if not state["night"]:
        for c in state["clouds"]: draw_cloud(screen,int(c["x"]),int(c["y"]))
    draw_ground(screen,state["ground_off"])

    for o in state["obstacles"]:
        ox=int(o["x"])
        if o["kind"] in ("pipe","piranha"): draw_pipe(screen,ox,o["wc"],o["hc"])
    for o in state["obstacles"]:
        ox=int(o["x"])
        if o["kind"]=="piranha":
            ptop=pipe_cap_top(ox,o["wc"],o["hc"])
            draw_piranha(screen,ox,ptop,state["frame"],o["wc"],o["hc"])
        elif o["kind"]=="goomba": draw_goomba(screen,o["x"],o["y"],state["frame"])
        elif o["kind"]=="shell":  draw_koopa(screen,o["x"],o["y"],state["frame"])
        elif o["kind"]=="fbrick": draw_flying_bricks(screen,ox,int(o["y"]),o["count"],o["collected"])
        elif o["kind"]=="bullet": draw_bullet_bill(screen,o["x"],o["y"])

    draw_mario(screen,state["mx"],int(state["my"]),state["ducking"],state["airborne"],state["frame"])

    for pp in popups:
        screen.blit(font_sm.render(pp["text"],True,pp["color"]),(int(pp["x"]),int(pp["y"])))

    # HUD
    shadow_text(screen,font_med,f"SCORE  {int(state['score']):05d}",(252,252,252),W-242,12)
    shadow_text(screen,font_med,f"BEST   {state['hi']:05d}",(252,218,80),W-242,34)
    draw_coin_hud(screen,28,22)
    shadow_text(screen,font_med,f"x{state['coins']:02d}",COIN_Y,42,14)
    # Double jump indicator
    if state["night"]:
        shadow_text(screen,font_sm,"* NIGHT *",(172,172,252),W//2-42,10)

    if state["over"]:
        if state["flash"]>0:
            if state["flash"]%3<2:
                fs=pygame.Surface((W,H),pygame.SRCALPHA); fs.fill((*FLASH_C,92))
                screen.blit(fs,(0,0))
            state["flash"]-=1
        panel=pygame.Surface((450,170),pygame.SRCALPHA); panel.fill((0,0,0,168))
        screen.blit(panel,(W//2-225,H//2-90))
        shadow_text(screen,font_big,"GAME OVER",(252,48,48),W//2-100,H//2-78)
        shadow_text(screen,font_med,f"Score:{int(state['score'])}  Best:{state['hi']}",(252,216,80),W//2-150,H//2-30)
        shadow_text(screen,font_med,"SPACE / UP  to play again",(252,252,252),W//2-152,H//2+10)

    pygame.display.flip()
